{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cocoya (Extension)",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}",
                "--profile=VSIX Dev"
            ],
            "outFiles": [
                "${workspaceFolder}/out/**/*.js"
            ],
            "preLaunchTask": "compile-extension"
        }
    ]
}
