FROM nvcr.io/nvidia/pytorch:25.04-py3

WORKDIR /workspace

# 安裝 TensorFlow 和其他必要套件
RUN pip install --no-cache-dir \
    tensorflow==2.16.1 \
    scikit-learn \
    pillow \
    matplotlib

# 複製訓練腳本
COPY train_classifier.py .

# 建立輸出目錄
RUN mkdir -p /output

ENTRYPOINT ["python", "train_classifier.py"]