{
  "productName": "Cocoya",
  "version": "0.7.5",
  "identifier": "com.cocoya.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cocoya: Code, Compute, Yield AI",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "maximized": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "language": ["zh-TW"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/deploy_mcu.py": "resources/deploy_mcu.py",
      "../ui/src/core_manifest.json": "resources/core_manifest.json",
      "../resources/firmware": "resources/firmware",
      "../ui/src/modules": "resources/modules"
    }
  }
}
