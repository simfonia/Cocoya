{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Cocoya",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "dialog:default",
    "fs:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:window:allow-set-title",
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "schemes": [
            "http",
            "https"
          ]
        }
      ]
    }
  ]
}
