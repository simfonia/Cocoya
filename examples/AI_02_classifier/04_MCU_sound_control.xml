<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- 初始化 -->
  <block type="mcu_setup" x="10" y="10">
    <next>
      <!-- 初始化 Serial -->
      <block type="serial_init">
        <field name="BAUD">115200</field>
        <next>
          <!-- 初始化蜂鳴器 -->
          <block type="buzzer_setup">
            <field name="PIN">21</field>
            <next>
              <!-- 初始化 LED -->
              <block type="led_setup">
                <field name="PIN">25</field>
                <next>
                  <!-- 主迴圈 -->
                  <block type="controls_whileTrue">
                    <statement name="DO">
                      <!-- 讀取 Serial 資料 -->
                      <block type="serial_read">
                        <field name="VAR">gesture_data</field>
                        <next>
                          <!-- 檢查是否有資料 -->
                          <block type="controls_if">
                            <value name="IF0">
                              <block type="logic_compare">
                                <field name="OP">NEQ</field>
                                <value name="A">
                                  <block type="variables_get">
                                    <field name="VAR">gesture_data</field>
                                  </block>
                                </value>
                                <value name="B">
                                  <shadow type="text">
                                    <field name="TEXT"></field>
                                  </shadow>
                                </value>
                              </block>
                            </value>
                            <statement name="DO0">
                              <!-- 轉換為數字 -->
                              <block type="variables_set">
                                <field name="VAR">gesture_id</field>
                                <value name="VALUE">
                                  <block type="math_number_cast">
                                    <value name="NUM">
                                      <block type="variables_get">
                                        <field name="VAR">gesture_data</field>
                                      </block>
                                    </value>
                                  </block>
                                </value>
                                <next>
                                  <!-- 判斷手勢類別 -->
                                  <block type="controls_if">
                                    <value name="IF0">
                                      <block type="logic_compare">
                                        <field name="OP">EQ</field>
                                        <value name="A">
                                          <block type="variables_get">
                                            <field name="VAR">gesture_id</field>
                                          </block>
                                        </value>
                                        <value name="B">
                                          <shadow type="math_number">
                                            <field name="NUM">0</field>
                                          </shadow>
                                        </value>
                                      </block>
                                    </value>
                                    <statement name="DO0">
                                      <!-- 手勢 0: Do (262Hz) -->
                                      <block type="buzzer_tone">
                                        <field name="FREQ">262</field>
                                        <field name="DURATION">500</field>
                                      </block>
                                      <next>
                                        <block type="led_on">
                                          <field name="PIN">25</field>
                                        </block>
                                      </next>
                                    </statement>
                                    <next>
                                      <block type="controls_if">
                                        <value name="IF0">
                                          <block type="logic_compare">
                                            <field name="OP">EQ</field>
                                            <value name="A">
                                              <block type="variables_get">
                                                <field name="VAR">gesture_id</field>
                                              </block>
                                            </value>
                                            <value name="B">
                                              <shadow type="math_number">
                                                <field name="NUM">1</field>
                                              </shadow>
                                            </value>
                                          </block>
                                        </value>
                                        <statement name="DO0">
                                          <!-- 手勢 1: Re (294Hz) -->
                                          <block type="buzzer_tone">
                                            <field name="FREQ">294</field>
                                            <field name="DURATION">500</field>
                                          </block>
                                          <next>
                                            <block type="led_on">
                                              <field name="PIN">25</field>
                                            </block>
                                          </next>
                                        </statement>
                                        <next>
                                          <block type="controls_if">
                                            <value name="IF0">
                                              <block type="logic_compare">
                                                <field name="OP">EQ</field>
                                                <value name="A">
                                                  <block type="variables_get">
                                                    <field name="VAR">gesture_id</field>
                                                  </block>
                                                </value>
                                                <value name="B">
                                                  <shadow type="math_number">
                                                    <field name="NUM">2</field>
                                                  </shadow>
                                                </value>
                                              </block>
                                            </value>
                                            <statement name="DO0">
                                              <!-- 手勢 2: Mi (330Hz) -->
                                              <block type="buzzer_tone">
                                                <field name="FREQ">330</field>
                                                <field name="DURATION">500</field>
                                              </block>
                                              <next>
                                                <block type="led_on">
                                                  <field name="PIN">25</field>
                                                </block>
                                              </next>
                                            </statement>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </statement>
                          </block>
                        </next>
                      </block>
                    </statement>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>